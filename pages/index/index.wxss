.container {
  width: 100%;
  height: 100vh;
  background-color: #1a1a1a;
  overflow: hidden;
  position: relative;
}

canvas {
  display: block;
}

/* 菜单覆盖层 */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  overflow-y: auto;
}

.menu-content {
  background: linear-gradient(135deg, #2c2c2c 0%, #1a1a1a 100%);
  border: 4px solid #ff6b00;
  border-radius: 8px;
  padding: 40px 30px;
  text-align: center;
  max-width: 350px;
  width: 90%;
  margin: 20px auto;
}

.leaderboard-content,
.achievements-content {
  max-width: 380px;
  max-height: 70vh;
  overflow-y: auto;
}

.game-title {
  font-size: 40px;
  font-weight: bold;
  color: #ff6b00;
  display: block;
  margin-bottom: 10px;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
}

.game-subtitle {
  font-size: 16px;
  color: #888;
  display: block;
  margin-bottom: 30px;
}

.menu-title {
  font-size: 28px;
  font-weight: bold;
  color: #ff6b00;
  display: block;
  margin-bottom: 20px;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #ffcc00;
  display: block;
  margin: 15px 0 10px 0;
  text-align: left;
}

/* 按钮样式 */
.btn-start,
.btn-restart,
.btn-instructions,
.btn-leaderboard,
.btn-achievements,
.btn-back,
.btn-menu,
.btn-continue,
.difficulty-btn {
  width: 100%;
  padding: 12px 20px;
  margin-bottom: 10px;
  background-color: #ff6b00;
  color: #fff;
  font-size: 16px;
  font-weight: bold;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-start:active,
.btn-restart:active,
.btn-instructions:active,
.btn-leaderboard:active,
.btn-achievements:active,
.btn-back:active,
.btn-menu:active,
.btn-continue:active,
.difficulty-btn:active {
  background-color: #ff8c00;
  transform: scale(0.98);
}

.btn-back,
.btn-menu {
  background-color: #666;
}

.btn-back:active,
.btn-menu:active {
  background-color: #888;
}

/* 难度按钮 */
.difficulty-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15px;
}

.difficulty-btn.easy {
  background-color: #00aa00;
}

.difficulty-btn.normal {
  background-color: #ff6b00;
}

.difficulty-btn.hard {
  background-color: #ff0000;
}

.difficulty-btn.insane {
  background-color: #8800ff;
}

.difficulty-desc {
  font-size: 12px;
  margin-top: 5px;
  opacity: 0.9;
}

/* HUD */
.hud {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 10px 15px;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
  z-index: 500;
  flex-wrap: wrap;
}

.hud-left,
.hud-center,
.hud-right {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hud-label {
  font-size: 12px;
  color: #888;
}

.difficulty-label {
  color: #ffcc00;
  font-weight: bold;
}

.hud-value {
  font-size: 18px;
  color: #ff6b00;
  font-weight: bold;
}

.weapon-info {
  position: fixed;
  bottom: 20px;
  left: 20px;
  background-color: rgba(0, 0, 0, 0.7);
  border: 2px solid #ffcc00;
  border-radius: 4px;
  padding: 10px 15px;
  z-index: 100;
}

.weapon-type {
  color: #ffcc00;
  font-size: 14px;
  font-weight: bold;
}

/* 游戏统计 */
.stats {
  margin: 20px 0;
  text-align: left;
  background-color: rgba(255, 107, 0, 0.1);
  padding: 15px;
  border-radius: 4px;
}

.stat-line {
  display: block;
  font-size: 16px;
  color: #fff;
  margin: 8px 0;
}

/* 新解锁成就 */
.new-achievements {
  margin: 15px 0;
  background-color: rgba(255, 200, 0, 0.2);
  border: 2px solid #ffcc00;
  border-radius: 4px;
  padding: 15px;
}

.achievement-unlock-title {
  font-size: 16px;
  font-weight: bold;
  color: #ffcc00;
  display: block;
  margin-bottom: 10px;
}

.unlock-item {
  color: #fff;
  font-size: 14px;
  margin: 5px 0;
}

/* 说明文本 */
.instructions-text {
  display: flex;
  flex-direction: column;
  text-align: left;
  margin: 20px 0;
  background-color: rgba(255, 107, 0, 0.1);
  padding: 15px;
  border-radius: 4px;
}

.instructions-text text {
  color: #fff;
  font-size: 14px;
  margin: 8px 0;
  line-height: 1.6;
}

/* 排行榜 */
.leaderboard-list {
  text-align: left;
  margin: 15px 0;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  padding: 12px;
  margin: 8px 0;
  background-color: rgba(255, 107, 0, 0.1);
  border-radius: 4px;
  border-left: 4px solid #ff6b00;
}

.rank {
  font-size: 20px;
  font-weight: bold;
  color: #ffcc00;
  min-width: 40px;
  text-align: center;
}

.score-info {
  flex: 1;
  margin-left: 15px;
}

.score-name {
  display: block;
  color: #fff;
  font-size: 16px;
  font-weight: bold;
}

.score-detail {
  display: block;
  color: #888;
  font-size: 12px;
  margin-top: 4px;
}

/* 成就系统 */
.achievements-list {
  text-align: left;
  margin: 15px 0;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 12px;
  margin: 8px 0;
  background-color: rgba(255, 200, 0, 0.1);
  border-radius: 4px;
  border-left: 4px solid #ffcc00;
  transition: all 0.3s ease;
}

.achievement-icon {
  font-size: 28px;
  margin-right: 12px;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  display: block;
  color: #fff;
  font-size: 14px;
  font-weight: bold;
}

.achievement-desc {
  display: block;
  color: #888;
  font-size: 12px;
  margin-top: 4px;
}

.achievement-status {
  font-size: 16px;
  font-weight: bold;
  color: #ffcc00;
}

/* 升级菜单 */
.upgrade-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  overflow-y: auto;
}

.upgrade-content {
  background: linear-gradient(135deg, #2c2c2c 0%, #1a1a1a 100%);
  border: 4px solid #ffcc00;
  border-radius: 8px;
  padding: 30px 20px;
  text-align: center;
  max-width: 360px;
  width: 95%;
  margin: 20px auto;
}

.upgrade-title {
  font-size: 28px;
  font-weight: bold;
  color: #ffcc00;
  display: block;
  margin-bottom: 10px;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
}

.upgrade-points {
  font-size: 16px;
  color: #ff6b00;
  display: block;
  margin-bottom: 20px;
  font-weight: bold;
}

.upgrade-options {
  display: flex;
  flex-direction: column;
  margin-bottom: 15px;
}

.upgrade-btn {
  width: 100%;
  padding: 12px;
  margin-bottom: 10px;
  background-color: #444;
  color: #fff;
  border: 2px solid #ffcc00;
  border-radius: 4px;
  font-size: 13px;
  font-weight: bold;
  text-align: left;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  cursor: pointer;
  transition: all 0.2s ease;
}

.weapon-btn {
  border-color: #ff6b00;
}

.upgrade-btn:active {
  background-color: #ffcc00;
  color: #000;
  transform: scale(0.98);
}

.upgrade-desc {
  font-size: 12px;
  opacity: 0.8;
  margin-top: 4px;
}

.upgrade-cost {
  font-size: 11px;
  opacity: 0.7;
  margin-top: 4px;
}

.btn-continue {
  background-color: #ffcc00;
  color: #000;
  margin-top: 10px;
}